// dos_groundzero_rowcube_test.go — the exhaustive, ground-zero confidence suite.
//
// Motivated by docs/postmortem_365_exact_interest.md: the prior suite reported
// ~99 confidence yet shipped a real bug because it compared the wrong OUTPUT
// (the regular payment) on the one AXIS where the failure was invisible (360
// basis), and the cell that did expose it was quarantined. This suite is built
// to the docs/testing_policy.md rules:
//
//   - It compares EVERY UI-visible per-row quantity — payment, interest,
//     principal portion, remaining balance, and cumulative interest — not just a
//     summary scalar. (testing_policy §1)
//   - It crosses the full settings cube so interacting factors (exact × basis,
//     in-advance × basis, R78 × basis, …) are exercised together, not in
//     isolation. (testing_policy §2)
//   - It drives the real Amortize dispatch (the path the API/UI use) for the
//     payment solve, then feeds the DOS-solved payment to BOTH engines so the
//     per-row comparison isolates the accrual engine from payment-solve noise.
//     (testing_policy §3)
//   - A coverage map asserts every non-skipped cell was actually compared, and
//     the comparison is sensitive to the cell's axes (no vacuous green).
//
// Run requires the DOS oracle binary (build via legacy/oracle/build_linux.sh).

// fullRow is one oracle schedule row: the three printed columns.
type fullRow struct{ interest, prin, bal float64 }

// runOracleRowsFull drives the DOS engine in rows mode with an explicit payment
// and arbitrary setting flags, returning every row's interest / principal /
// balance. Parses `row N int X prin Y bal Z`.
func runOracleRowsFull(amount, rate float64, n, perYr int, pay float64, flags ...string) ([]fullRow, bool) {
	args := []string{
		strconv.FormatFloat(amount, 'f', 2, 64), strconv.FormatFloat(rate, 'f', 10, 64),
		strconv.Itoa(n), strconv.Itoa(perYr), "rows",
		"pay=" + strconv.FormatFloat(pay, 'f', 10, 64)}
	args = append(args, flags...)
	out, err := exec.Command(oracleBin, args...).Output()
	if err != nil {
		return nil, false
	}
	var rows []fullRow
	for _, ln := range strings.Split(strings.TrimSpace(string(out)), "\n") {
		f := strings.Fields(ln)
		if len(f) == 8 && f[0] == "row" {
			in, _ := strconv.ParseFloat(f[3], 64)
			pr, _ := strconv.ParseFloat(f[5], 64)
			bal, _ := strconv.ParseFloat(f[7], 64)
			rows = append(rows, fullRow{interest: in, prin: pr, bal: bal})
		}
	}
	if len(rows) == 0 {
		return nil, false
	}
	return rows, true
}

// gzSettings builds the Go Settings for a cube cell. yrInv mirrors the DOS
// SetYrDays convention used by the oracle (x365 → 365.25, x365_360 → actual/360).
func gzSettings(perYr int, basis types.BasisType, exact, prepaid, inadv, r78, usa bool) Settings {
	s := Settings{Basis: types.Basis360, PerYr: byte(perYr), YrDays: 360, YrInv: 1.0 / 360}
	switch basis {
	case types.Basis365:
		s.Basis, s.YrDays, s.YrInv = types.Basis365, 365.25, 1.0/365.25
	case types.Basis365360:
		s.Basis, s.YrDays, s.YrInv = types.Basis365360, 360, 1.0/360
	}
	s.Exact, s.Prepaid, s.InAdvance, s.R78, s.USARule = exact, prepaid, inadv, r78, usa
	return s
}

// gzGoSchedule solves the blank payment through the real Amortize dispatch, then
// (separately) builds the schedule with a SUPPLIED payment so it can be fed the
// DOS-solved payment for an apples-to-apples per-row comparison.
func gzGoSolvePayment(amount, rate float64, n, perYr int, s Settings) (float64, bool) {
	in := gzLoanInput(amount, rate, n, perYr, s)
	in.Loan.PayAmtStatus = types.StatusEmpty
	r := Amortize(in)
	if r.Err != nil || len(r.Schedule) == 0 {
		return 0, false
	}
	return modalReg(r.Schedule), true
}

func gzGoScheduleWithPayment(amount, rate float64, n, perYr int, s Settings, pay float64) (AmortResult, bool) {
	in := gzLoanInput(amount, rate, n, perYr, s)
	in.Loan.PayAmtStatus = types.InOutDefault // non-hard: no per-period Round2, matching the oracle's defp
	in.Loan.PayAmt = pay
	r := Amortize(in)
	if r.Err != nil || len(r.Schedule) == 0 {
		return r, false
	}
	return r, true
}

func gzLoanInput(amount, rate float64, n, perYr int, s Settings) LoanInput {
	return LoanInput{Loan: Loan{
		AmountStatus: types.InOutInput, Amount: amount,
		LoanRateStatus: types.InOutInput, LoanRate: rate,
		NStatus: types.InOutInput, NPeriods: n, PerYrStatus: types.InOutInput, PerYr: perYr,
		PayAmtStatus:   types.StatusEmpty,
		LoanDateStatus: types.InOutInput, LoanDate: types.NewDateRec(2024, time.January, 1),
		FirstStatus: types.InOutInput, FirstDate: firstPeriodDate(perYr)},
		Settings: s}
}

func basisFlag(b types.BasisType) (string, bool) {
	switch b {
	case types.Basis365:
		return "b365", true
	case types.Basis365360:
		return "b365_360", true
	default:
		return "", false
	}
}

func basisName(b types.BasisType) string {
	switch b {
	case types.Basis365:
		return "365"
	case types.Basis365360:
		return "365/360"
	default:
		return "360"
	}
}

// TestDOSGroundZeroRowCube is the exhaustive settings-cube row-level differential.
func TestDOSGroundZeroRowCube(t *testing.T) {
	if _, err := os.Stat(oracleBin); err != nil {
		t.Skipf("DOS oracle binary not present (%s); build via legacy/oracle/build_linux.sh", oracleBin)
	}

	bases := []types.BasisType{types.Basis360, types.Basis365, types.Basis365360}
	perYrs := []int{1, 2, 4, 12}
	// The interest/timing METHODS are mutually-exclusive configurations in DOS
	// (the UI surfaces them as separate dropdowns, and the original validates
	// them one at a time). Cross each method with the composable axes
	// (basis × exact × prepaid × perYr) rather than all-cross-all, which would
	// drive undefined triple-method combinations.
	methods := []struct {
		name              string
		inadv, r78, usa   bool
	}{
		{"ordinary", false, false, false},
		{"in-advance", true, false, false},
		{"r78", false, true, false},
		{"usa", false, false, true},
	}
	// Value grid (amount × rate × years). Kept modest so the full cube stays in
	// the low thousands of oracle spawns.
	amounts := []float64{50000, 200000}
	rates := []float64{0.06, 0.11}
	yearsList := []int{8, 20}

	// Per-row tolerance: the engines are fed the SAME payment, so a faithful
	// port tracks to the cent. Allow one cent of display rounding plus a tiny
	// relative slack for large balances.
	tol := func(v float64) float64 { return 0.01 + 1e-6*math.Abs(v) }
	// Payment-solve tolerance (Go's solved payment vs DOS's solved payment).
	payTol := 0.02

	type cellStat struct {
		checked, rowFails, payFails int
		maxRowErr, maxPayErr        float64
	}
	cells := map[string]*cellStat{}
	totalChecked, totalRowFails, totalPayFails := 0, 0, 0
	var worstRow, worstPay string
	maxRowErr, maxPayErr := 0.0, 0.0
	reported := 0

	for _, basis := range bases {
		bf, hasBF := basisFlag(basis)
		for _, exact := range []bool{false, true} {
			// exact is meaningful only on a non-360 basis (DOS no-op on 360);
			// still exercise exact×360 to prove it stays a no-op.
			for _, prepaid := range []bool{false, true} {
				for _, method := range methods {
					inadv, r78, usa := method.inadv, method.r78, method.usa
					{
						for _, perYr := range perYrs {
								// Assemble the oracle flag set.
								var flags []string
								if hasBF {
									flags = append(flags, bf)
								}
								if exact {
									flags = append(flags, "exact")
								}
								if prepaid {
									flags = append(flags, "prepaid")
								}
								if inadv {
									flags = append(flags, "inadv")
								}
								if r78 {
									flags = append(flags, "r78")
								}
								if usa {
									flags = append(flags, "usa")
								}
								cell := fmt.Sprintf("basis=%s|exact=%v|prepaid=%v|method=%s|py=%d",
									basisName(basis), exact, prepaid, method.name, perYr)
								cs := cells[cell]
								if cs == nil {
									cs = &cellStat{}
									cells[cell] = cs
								}
								s := gzSettings(perYr, basis, exact, prepaid, inadv, r78, usa)

								for _, amount := range amounts {
									for _, rate := range rates {
										for _, ny := range yearsList {
											n := ny * perYr
											// DOS-solved payment for this cell.
											dosPay, ok := runOraclePayment(amount, rate, n, perYr, flags...)
											if !ok || dosPay <= 0 {
												continue
											}
											// (a) Go-solved payment vs DOS-solved payment.
											goPay, gok := gzGoSolvePayment(amount, rate, n, perYr, s)
											if !gok {
												continue
											}
											// (b) Feed the DOS payment to both engines, compare rows.
											dosRows, ok2 := runOracleRowsFull(amount, rate, n, perYr, dosPay, flags...)
											goRes, gok2 := gzGoScheduleWithPayment(amount, rate, n, perYr, s, dosPay)
											if !ok2 || !gok2 {
												continue
											}
											cs.checked++
											totalChecked++

											payErr := math.Abs(goPay - dosPay)
											if payErr > cs.maxPayErr {
												cs.maxPayErr = payErr
											}
											if payErr > maxPayErr {
												maxPayErr = payErr
												worstPay = fmt.Sprintf("%s amt=%.0f r=%.2f n=%d DOS=%.4f Go=%.4f", cell, amount, rate, n, dosPay, goPay)
											}
											if payErr > payTol {
												cs.payFails++
												totalPayFails++
											}

											// Align row counts: compare the overlap (Go may carry a
											// settlement row 0 the oracle's row list also includes).
											goSched := goRes.Schedule
											if len(goSched) != len(dosRows) {
												cs.rowFails++
												totalRowFails++
												if reported < 25 {
													t.Errorf("[%s] amt=%.0f r=%.2f n=%d: ROW COUNT DOS=%d Go=%d",
														cell, amount, rate, n, len(dosRows), len(goSched))
													reported++
												}
												continue
											}
											var cum float64
											for k := range dosRows {
												gi := goSched[k].Interest
												gp := goSched[k].PayAmt - goSched[k].Interest // principal portion
												gb := goSched[k].Principal                    // remaining balance
												cum += dosRows[k].interest
												diExact := math.Abs(dosRows[k].interest - gi)
												dpExact := math.Abs(dosRows[k].prin - gp)
												dbExact := math.Abs(dosRows[k].bal - gb)
												worst := math.Max(diExact, math.Max(dpExact, dbExact))
												if worst > cs.maxRowErr {
													cs.maxRowErr = worst
												}
												if worst > maxRowErr {
													maxRowErr = worst
													worstRow = fmt.Sprintf("%s amt=%.0f r=%.2f n=%d row=%d int(D=%.4f G=%.4f) prin(D=%.4f G=%.4f) bal(D=%.4f G=%.4f)",
														cell, amount, rate, n, k+1,
														dosRows[k].interest, gi, dosRows[k].prin, gp, dosRows[k].bal, gb)
												}
												if diExact > tol(gi) || dpExact > tol(gp) || dbExact > tol(gb) {
													cs.rowFails++
													totalRowFails++
													if reported < 25 {
														t.Errorf("[%s] amt=%.0f r=%.2f n=%d row=%d: int D=%.4f G=%.4f | prin D=%.4f G=%.4f | bal D=%.4f G=%.4f",
															cell, amount, rate, n, k+1,
															dosRows[k].interest, gi, dosRows[k].prin, gp, dosRows[k].bal, gb)
														reported++
													}
												}
											}
											// Cumulative-interest (Int to Date) check on the last row.
											if len(goSched) > 0 {
												gCum := goSched[len(goSched)-1].IntToDate
												if math.Abs(gCum-cum) > 0.02+1e-5*math.Abs(cum) {
													cs.rowFails++
													totalRowFails++
													if reported < 25 {
														t.Errorf("[%s] amt=%.0f r=%.2f n=%d: CUM INT DOS=%.2f Go=%.2f",
															cell, amount, rate, n, cum, gCum)
														reported++
													}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}

	// Coverage: every cell must have been compared on a sensitive output.
	uncovered := 0
	for cell, cs := range cells {
		if cs.checked == 0 {
			uncovered++
			if uncovered <= 15 {
				t.Logf("UNCOVERED cell (oracle produced no comparable case): %s", cell)
			}
		}
	}
	t.Logf("ground-zero row cube: %d cells, %d comparisons, row fails=%d (max row err=%.4f at [%s]), pay fails=%d (max pay err=%.4f at [%s]), uncovered cells=%d",
		len(cells), totalChecked, totalRowFails, maxRowErr, worstRow, totalPayFails, maxPayErr, worstPay, uncovered)
	if totalChecked < 500 {
		t.Fatalf("only %d comparisons ran — oracle may be flaking or skipping too much", totalChecked)
	}
}
